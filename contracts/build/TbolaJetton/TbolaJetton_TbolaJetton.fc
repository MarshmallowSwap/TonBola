            var $msg'amount = in_msg~load_varuint16();
            var $msg'receiver = in_msg~load_msg_addr();
            throw_unless(57579, ( equal_slices_bits(__tact_context_get_sender(), $self'owner) ));
            throw_unless(56760, $self'mintable);
            int $max_airdrop = 400000000000000000;
            throw_unless(56249, (($self'minted_airdrop + $msg'amount) <= $max_airdrop));
            ($self'total_supply, $self'mintable, $self'owner, $self'minted_airdrop, $self'minted_presale, $self'minted_liquidity, $self'minted_team, $self'minted_marketing, $self'minted_reserve, $self'presale_wallet, $self'liquidity_wallet, $self'team_wallet, $self'marketing_wallet, $self'reserve_wallet, $self'team_vesting_start, $self'team_vesting_claimed)~$TbolaJetton$_fun_mintInternal($msg'receiver, $msg'amount);
            $self'minted_airdrop = ($self'minted_airdrop + $msg'amount);
            $TbolaJetton$_contract_store(($self'total_supply, $self'mintable, $self'owner, $self'minted_airdrop, $self'minted_presale, $self'minted_liquidity, $self'minted_team, $self'minted_marketing, $self'minted_reserve, $self'presale_wallet, $self'liquidity_wallet, $self'team_wallet, $self'marketing_wallet, $self'reserve_wallet, $self'team_vesting_start, $self'team_vesting_claimed));
            return ();
        }
        
        ;; Receive BurnNotification message
        if (op == 0x7bdd97de) {
            var $msg'query_id = in_msg~load_uint(64);
            var $msg'amount = in_msg~load_varuint16();
            var $msg'sender = in_msg~load_msg_addr();
            var $msg'response_destination = in_msg~load_msg_addr();
            var ($wallet_init'code, $wallet_init'data) = $TbolaWallet$_init_child($msg'sender, $global_myAddress());
            throw_unless(36088, ( equal_slices_bits(__tact_context_get_sender(), $global_contractAddress(($wallet_init'code, $wallet_init'data))) ));
            $self'total_supply = ($self'total_supply - $msg'amount);
            if (( ~ equal_slices_bits($msg'response_destination, __gen_slice_address_61ab4641fa30d9310391025086eec65d200d79268e1b7cd402565e01ba64be3c()) )) {
                $global_send($SendParameters$_constructor_to_value_mode_bounce_body($msg'response_destination, 0, 66, false, $Excesses$_store_cell($Excesses$_constructor_query_id($msg'query_id), begin_cell())));
            }
            $TbolaJetton$_contract_store(($self'total_supply, $self'mintable, $self'owner, $self'minted_airdrop, $self'minted_presale, $self'minted_liquidity, $self'minted_team, $self'minted_marketing, $self'minted_reserve, $self'presale_wallet, $self'liquidity_wallet, $self'team_wallet, $self'marketing_wallet, $self'reserve_wallet, $self'team_vesting_start, $self'team_vesting_claimed));
            return ();
        }
        
        ;; Receive ProvideWalletAddress message
        if (op == 0x2c76b973) {
            var $msg'query_id = in_msg~load_uint(64);
